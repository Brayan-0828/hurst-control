<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ServicioController"
      style="-fx-background-color: #131924;"
      VBox.vgrow="ALWAYS">

    <VBox spacing="4" style="-fx-background-color: #1a2333; -fx-padding: 20 28; -fx-border-color: #26334d; -fx-border-width: 0 0 1 0;">
        <Label text="Servicios Hospitalarios" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
        <Label text="Gestión de áreas médicas, ubicaciones físicas y límites de capacidad" style="-fx-font-size: 12px; -fx-text-fill: #7085a3;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 24 28 28 28; -fx-background-color: #131924;">

            <VBox spacing="18" style="-fx-background-color: #1a2333; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;">
                <Label text="Detalles del Servicio" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

                <GridPane hgap="24" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints minWidth="70" prefWidth="80" halignment="LEFT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                        <ColumnConstraints minWidth="80" prefWidth="90" halignment="LEFT"/>
                        <ColumnConstraints hgrow="NEVER" prefWidth="120"/>
                    </columnConstraints>

                    <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtNombre" promptText="Ej. Urgencias, Pediatría..." GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"
                               style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;"/>

                    <Label text="Cap. máx.:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtCapacidad" promptText="Ej. 25" GridPane.rowIndex="0" GridPane.columnIndex="3"
                               style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;"/>

                    <Label text="Ubicación:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtUbicacion" promptText="Ej. Piso 2 - Ala Norte" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.hgrow="ALWAYS"
                               style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;"/>
                </GridPane>

                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                    <Button onAction="#eliminar" prefWidth="130" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #441c1c; -fx-text-fill: #ffa3a3; -fx-border-color: #733030; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="#ffa3a3" scaleX="0.8" scaleY="0.8"/>
                                <Label text="Eliminar" style="-fx-text-fill: #ffa3a3; -fx-font-weight: bold;"/>
                            </HBox>
                        </graphic>
                    </Button>
                    <Button onAction="#guardar" prefWidth="130" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #103c27; -fx-text-fill: #52d689; -fx-border-color: #1b6642; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" fill="#52d689" scaleX="0.8" scaleY="0.8"/>
                                <Label text="Guardar" style="-fx-text-fill: #52d689; -fx-font-weight: bold;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="14" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a2333; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;">
                <Label text="Inventario de Áreas y Capacidad" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <TableView fx:id="tablaServicios" VBox.vgrow="ALWAYS" prefHeight="360" style="-fx-background-color: #131924; -fx-border-color: #26334d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-control-inner-background: #131924; -fx-table-cell-border-color: #1e293b; -fx-text-fill: #cbd5e1; -fx-selection-bar: #233147; -fx-selection-bar-non-focused: #192436;">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    <placeholder><Label text="No hay áreas médicas o servicios configurados actualmente." style="-fx-text-fill: #4b5e78; -fx-font-size: 13px;"/></placeholder>
                    <columns>
                        <TableColumn fx:id="colId" text="ID" maxWidth="80" minWidth="50"/>
                        <TableColumn fx:id="colNombre" text="Servicio" minWidth="200"/>
                        <TableColumn fx:id="colUbicacion" text="Ubicación" minWidth="180"/>
                        <TableColumn fx:id="colCapacidad" text="Cap. Máx." minWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>