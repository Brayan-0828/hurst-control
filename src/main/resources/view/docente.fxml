<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox spacing="0" style="-fx-background-color: #131924;" VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="controller.DocenteController">

    <VBox spacing="4" style="-fx-background-color: #1a2333; -fx-padding: 20 28; -fx-border-color: #26334d; -fx-border-width: 0 0 1 0;">
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Gestión de Docentes" />
        <Label style="-fx-font-size: 12px; -fx-text-fill: #7085a3;" text="Registro de profesores, vinculación institucional y datos de contacto" />
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 24 28 28 28; -fx-background-color: #131924;">

            <VBox spacing="18" style="-fx-background-color: #1a2333; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Información del Docente" />

                <GridPane hgap="24" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" minWidth="90" prefWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                        <ColumnConstraints halignment="LEFT" minWidth="90" prefWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                    </columnConstraints>

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;" text="Cédula:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtCedula" promptText="Ej. 10203040" style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;" text="Nombre:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="txtNombre" promptText="Nombre completo del docente" style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;" text="Correo:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="txtCorreo" promptText="ejemplo@universidad.edu.co" style="-fx-background-color: #131924; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;" text="Universidad:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cbUniversidad" maxWidth="1.7976931348623157E308" promptText="Seleccione universidad..." style="-fx-background-color: #d9ecff; -fx-border-color: #344869; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4; -fx-text-fill: #ffffff;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 8 0 0 0;">
                    <Button onAction="#eliminar" prefWidth="130" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #441c1c; -fx-text-fill: #ffa3a3; -fx-border-color: #733030; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="#ffa3a3" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #ffa3a3; -fx-font-weight: bold;" text="Eliminar" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button onAction="#guardar" prefWidth="130" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #103c27; -fx-text-fill: #52d689; -fx-border-color: #1b6642; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" fill="#52d689" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #52d689; -fx-font-weight: bold;" text="Guardar" />
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="14" style="-fx-background-color: #1a2333; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Docentes Registrados" />
                <TableView fx:id="tablaDocentes" prefHeight="340" style="-fx-background-color: #131924; -fx-border-color: #26334d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-control-inner-background: #131924; -fx-table-cell-border-color: #1e293b; -fx-text-fill: #cbd5e1; -fx-selection-bar: #233147; -fx-selection-bar-non-focused: #192436;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <placeholder><Label style="-fx-text-fill: #4b5e78; -fx-font-size: 13px;" text="No se encuentran docentes registrados en la base de datos." /></placeholder>
                    <columns>
                        <TableColumn fx:id="colId" maxWidth="80" minWidth="50" text="ID" />
                        <TableColumn fx:id="colCedula" minWidth="110" text="Cédula" />
                        <TableColumn fx:id="colNombre" minWidth="200" text="Nombre" />
                        <TableColumn fx:id="colCorreo" minWidth="180" text="Correo" />
                        <TableColumn fx:id="colUniversidad" minWidth="170" text="Universidad" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
