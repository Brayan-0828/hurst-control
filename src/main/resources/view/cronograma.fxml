<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox spacing="0" style="-fx-background-color: #152246;" VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="controller.CronogramaController">

    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #1e3163; -fx-padding: 16 28; -fx-border-color: #2d4682; -fx-border-width: 0 0 1 0;">
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Cronogramas de Prácticas" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #cbd6ea;" text="Asignación de turnos, control de horarios por servicio y gestión de estados de aprobación" />
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 24 28; -fx-background-color: #152246;">

            <VBox spacing="18" style="-fx-background-color: #1e3163; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #2d4682; -fx-border-width: 1;">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Planificación del Turno" />

                <GridPane hgap="24" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" minWidth="130" prefWidth="140" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="160" />
                        <ColumnConstraints halignment="LEFT" minWidth="130" prefWidth="140" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="160" />
                    </columnConstraints>

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Estudiante:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox fx:id="cbEstudiante" maxWidth="1.7976931348623157E308" promptText="Seleccione alumno..." style="-fx-background-color: #d9ecff; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Docente:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <ComboBox fx:id="cbDocente" maxWidth="1.7976931348623157E308" promptText="Seleccione supervisor..." style="-fx-background-color: #d9ecff; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #ffffff;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Servicio:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cbServicio" maxWidth="1.7976931348623157E308" promptText="Seleccione área médica..." style="-fx-background-color: #d9ecff; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox fx:id="cbEstado" maxWidth="1.7976931348623157E308" promptText="Estado inicial..." style="-fx-background-color: #d9ecff; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Fecha:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <DatePicker fx:id="dpFecha" maxWidth="1.7976931348623157E308" promptText="dd/mm/aaaa" style="-fx-background-color: transparent; -fx-control-inner-background: #d9ecff; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-padding: 2; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #ffffff;" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Hora inicio (HH:mm):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtHoraInicio" promptText="07:00" style="-fx-background-color: #152246; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #8fa7cc;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label style="-fx-font-size: 13px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Hora fin (HH:mm):" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <TextField fx:id="txtHoraFin" promptText="13:00" style="-fx-background-color: #152246; -fx-border-color: #3d5c9e; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #8fa7cc;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 8 0 0 0;">
                    <Button onAction="#eliminar" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #5c2424; -fx-text-fill: #ffa3a3; -fx-border-color: #8c3b3b; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="#ffa3a3" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #ffa3a3; -fx-font-weight: bold;" text="Eliminar" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button onAction="#rechazar" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #613b18; -fx-text-fill: #ffb875; -fx-border-color: #945b27; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="#ffb875" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #ffb875; -fx-font-weight: bold;" text="Rechazar" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button onAction="#aprobar" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #144d32; -fx-text-fill: #52d689; -fx-border-color: #1f734b; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="#52d689" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #52d689; -fx-font-weight: bold;" text="Aprobar" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button onAction="#guardar" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #1a4a7d; -fx-text-fill: #a3d3ff; -fx-border-color: #2b6cb0; -fx-border-radius: 6;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <SVGPath content="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" fill="#a3d3ff" scaleX="0.8" scaleY="0.8" />
                                <Label style="-fx-text-fill: #a3d3ff; -fx-font-weight: bold;" text="Guardar" />
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="14" style="-fx-background-color: #1e3163; -fx-background-radius: 8; -fx-padding: 22; -fx-border-color: #2d4682; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Cronogramas y Turnos Agendados" />
                <TableView fx:id="tablaCronogramas" prefHeight="340" style="-fx-background-color: #152246; -fx-border-color: #2d4682; -fx-border-radius: 6; -fx-background-radius: 6; -fx-control-inner-background: #152246; -fx-table-cell-border-color: #2d4682; -fx-text-fill: #ffffff; -fx-selection-bar: #2a437e; -fx-selection-bar-non-focused: #203562;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <placeholder><Label style="-fx-text-fill: #cbd6ea; -fx-font-size: 13px;" text="No hay cronogramas asignados o planificados para este período." /></placeholder>
                    <columns>
                        <TableColumn fx:id="colId" maxWidth="64" minWidth="45" text="ID" />
                        <TableColumn fx:id="colEstudiante" minWidth="150" text="Estudiante" />
                        <TableColumn fx:id="colDocente" minWidth="150" text="Docente" />
                        <TableColumn fx:id="colServicio" minWidth="130" text="Servicio" />
                        <TableColumn fx:id="colFecha" minWidth="100" text="Fecha" />
                        <TableColumn fx:id="colInicio" minWidth="85" text="H. Inicio" />
                        <TableColumn fx:id="colFin" minWidth="85" text="H. Fin" />
                        <TableColumn fx:id="colEstado" minWidth="100" text="Estado" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
