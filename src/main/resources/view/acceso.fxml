<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AccesoController"
      style="-fx-background-color: #131924;"
      VBox.vgrow="ALWAYS">

    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: #1a2333; -fx-padding: 16 28 16 28;
                 -fx-border-color: #26334d; -fx-border-width: 0 0 1 0;">

        <Button onAction="#volverAlMenu"
                style="-fx-background-color: #233147; -fx-padding: 8 16;
                       -fx-background-radius: 6; -fx-border-color: #344869;
                       -fx-border-radius: 6; -fx-cursor: hand;">
            <graphic>
                <HBox spacing="8" alignment="CENTER">
                    <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#64d2ff" scaleX="0.9" scaleY="0.9"/>
                    <Label text="Volver" style="-fx-text-fill: #64d2ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>
            </graphic>
        </Button>

        <Separator orientation="VERTICAL" style="-fx-background-color: #26334d;" prefHeight="24"/>

        <VBox spacing="2">
            <Label text="Control de Acceso"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
            <Label text="Monitoreo de ingresos, salidas y permanencia en tiempo real"
                   style="-fx-font-size: 12px; -fx-text-fill: #7085a3;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">

        <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #131924;">

            <HBox spacing="16">

                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a2333; -fx-background-radius: 8;
                             -fx-padding: 20; -fx-border-color: #26334d; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5.48 13.29l6.52 3.56 6.52-3.56V16l-6.52 3.56-6.52-3.56v-2.71z"
                                 fill="#a0b2cc" scaleX="0.95" scaleY="0.95"/>
                        <Label text="Estudiantes en el Hospital"
                               style="-fx-font-size: 11px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;"/>
                    </HBox>
                    <Label fx:id="lblContador" text="0"
                           style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #64d2ff; -fx-padding: 4 0 0 0;"/>
                    <Label text="activos ahora en las instalaciones"
                           style="-fx-font-size: 11px; -fx-text-fill: #5a6e85;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a2333; -fx-background-radius: 8;
                             -fx-padding: 20; -fx-border-color: #26334d; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle fx:id="semaforo" radius="9" fill="#54657a"/>
                        <Label fx:id="lblEstado" text="Esperando cédula..."
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                    </HBox>
                    <Label fx:id="lblMensaje" text="Ingrese el documento del alumno para verificar su autorización de acceso."
                           style="-fx-font-size: 12px; -fx-text-fill: #859bb8;" wrapText="true" maxWidth="450"/>
                </VBox>

            </HBox>

            <VBox spacing="16"
                  style="-fx-background-color: #1a2333; -fx-background-radius: 8;
                         -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;">

                <Label text="Panel de Registro Operativo"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <Label text="Cédula de Identidad:"
                           style="-fx-font-size: 12px; -fx-text-fill: #a0b2cc; -fx-font-weight: bold;"/>

                    <TextField fx:id="txtCedula"
                               promptText="Ingrese o escanee el documento de identidad"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #131924; -fx-border-color: #344869;
                                      -fx-border-radius: 6; -fx-background-radius: 6;
                                      -fx-padding: 10 14; -fx-font-size: 13px;
                                      -fx-text-fill: #ffffff; -fx-prompt-text-fill: #4b5e78;"/>

                    <Button onAction="#registrarEntrada"
                            style="-fx-background-color: #103c27; -fx-text-fill: #52d689;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 10 22; -fx-background-radius: 6;
                                   -fx-border-color: #1b6642; -fx-border-radius: 6;
                                   -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <SVGPath content="M8 5v14l11-7z" fill="#52d689" scaleX="0.8" scaleY="0.8"/>
                                <Label text="Registrar ENTRADA" style="-fx-text-fill: #52d689; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button onAction="#registrarSalida"
                            style="-fx-background-color: #4c1a1a; -fx-text-fill: #ff8080;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 10 22; -fx-background-radius: 6;
                                   -fx-border-color: #802b2b; -fx-border-radius: 6;
                                   -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <SVGPath content="M6 19h12V5H6v14z" fill="#ff8080" scaleX="0.8" scaleY="0.8"/>
                                <Label text="Registrar SALIDA" style="-fx-text-fill: #ff8080; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="14" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #1a2333; -fx-background-radius: 8;
                         -fx-padding: 22; -fx-border-color: #26334d; -fx-border-width: 1;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Estudiantes Actualmente en Práctica"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox alignment="CENTER" spacing="8"
                          style="-fx-background-color: #172a45; -fx-background-radius: 20;
                                 -fx-padding: 5 16; -fx-border-color: #2a4c7a; -fx-border-width: 1;">
                        <Circle radius="4.5" fill="#64d2ff"/>
                        <Label fx:id="lblBadgeCount" text="0 estudiantes"
                               style="-fx-font-size: 11px; -fx-text-fill: #64d2ff; -fx-font-weight: bold;"/>
                    </HBox>
                </HBox>

                <TableView fx:id="tablaActivos" VBox.vgrow="ALWAYS" prefHeight="350"
                           style="-fx-background-color: #131924; -fx-border-color: #26334d;
                                  -fx-border-radius: 6; -fx-background-radius: 6;
                                  -fx-control-inner-background: #131924;
                                  -fx-table-cell-border-color: #1e293b;
                                  -fx-text-fill: #cbd5e1;
                                  -fx-selection-bar: #233147;
                                  -fx-selection-bar-non-focused: #192436;">

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <placeholder>
                        <Label text="Sin estudiantes registrados en el hospital en este momento."
                               style="-fx-text-fill: #4b5e78; -fx-font-size: 13px;"/>
                    </placeholder>

                    <columns>
                        <TableColumn fx:id="colId"         text="#"              maxWidth="64"  minWidth="48"/>
                        <TableColumn fx:id="colEstudiante" text="Estudiante"     minWidth="220"/>
                        <TableColumn fx:id="colCedula"     text="Cédula"         minWidth="130"/>
                        <TableColumn fx:id="colServicio"   text="Servicio"       minWidth="160"/>
                        <TableColumn fx:id="colEntrada"    text="Hora Entrada"   minWidth="150"/>
                        <TableColumn fx:id="colTiempo"     text="Tiempo (min)"   minWidth="110"/>
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </ScrollPane>

</VBox>